# Curio Garden — Environment Variables
# Copy this file to .env.local and fill in the values you need.

# ── Site URL ──────────────────────────────────────────────
# Used for metadataBase, OpenGraph image URLs, sitemap, and robots.txt.
# Set this to your production domain in Vercel.
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ── Convex ────────────────────────────────────────────────
# Auto-generated by `npx convex dev`. Not needed in local mode.
# NEXT_PUBLIC_CONVEX_URL=
# CONVEX_DEPLOYMENT=
# Set this in the Convex dashboard to your Clerk Frontend API URL
# after enabling the Convex integration or JWT template in Clerk.
# CLERK_JWT_ISSUER_DOMAIN=https://your-frontend-api.clerk.accounts.dev

# ── Clerk ─────────────────────────────────────────────────
# Optional for keyless local boot. Add these after claiming your Clerk app.
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
# CLERK_SECRET_KEY=

# ── Local Mode ────────────────────────────────────────────
# Set to "true" to run without Convex (browser-only storage, direct Wikipedia API calls).
# NEXT_PUBLIC_LOCAL_MODE=true

# ── TTS / Audio ──────────────────────────────────────────
# Route /api/tts to the standalone Python TTS server (used by `npm run dev:python`).
# USE_PYTHON_TTS=true

# Port for the standalone Python TTS server (default: 3001).
# TTS_PORT=3001

# Force smaller TTS chunks locally for testing. The client chunker reads the
# NEXT_PUBLIC value; the server routes also accept TTS_MAX_WORDS_PER_REQUEST.
# NEXT_PUBLIC_TTS_MAX_WORDS_PER_REQUEST=400
# TTS_MAX_WORDS_PER_REQUEST=400

# Secret used by the scheduled featured-podcast cron route.
# Vercel Cron will send it as an Authorization bearer token if configured.
# CRON_SECRET=replace-with-a-random-secret

# Vercel AI Gateway key for daily trending-brief generation.
# AI_GATEWAY_API_KEY=replace-with-your-vercel-ai-gateway-key

# Optional model overrides for the daily trending brief.
# TRENDING_BRIEF_MODEL=anthropic/claude-opus-4.5
# TRENDING_BRIEF_FALLBACK_MODEL=openai/gpt-5.2

# Path to a Python binary with edge-tts installed (default: /tmp/edge-tts-venv/bin/python3).
# EDGE_TTS_PYTHON_PATH=/path/to/python3
