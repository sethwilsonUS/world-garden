{
  "name": "curio-garden",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.13.0 <23"
  },
  "scripts": {
    "dev": "npm-run-all --parallel dev:frontend dev:backend",
    "dev:python": "npm-run-all --parallel dev:frontend-python dev:backend dev:tts-python",
    "dev:frontend": "next dev",
    "dev:frontend-python": "USE_PYTHON_TTS=true next dev",
    "dev:backend": "convex dev",
    "dev:tts-python": "bash scripts/ensure-edge-tts.sh scripts/dev-tts.py",
    "local": "LOCAL_MODE=true NEXT_PUBLIC_LOCAL_MODE=true next dev",
    "analytics:site": "node scripts/site-analytics-report.mjs",
    "build": "bash scripts/build.sh",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@ai-sdk/gateway": "^3.0.125",
    "@clerk/nextjs": "^7.4.3",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "ai": "^6.0.197",
    "convex": "^1.40.0",
    "next": "^16.2.7",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "^22.19.20",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.7",
    "jsdom": "^29.1.1",
    "npm-run-all": "^4.1.5",
    "playwright": "^1.60.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "overrides": {
    "postcss": "^8.5.10"
  }
}
