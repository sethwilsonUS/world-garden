{
  "name": "curio-garden",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.13.0 <23"
  },
  "scripts": {
    "dev": "npm-run-all --parallel dev:frontend dev:backend",
    "dev:python": "npm-run-all --parallel dev:frontend-python dev:backend dev:tts-python",
    "dev:frontend": "next dev",
    "dev:frontend-python": "USE_PYTHON_TTS=true next dev",
    "dev:backend": "convex dev",
    "dev:tts-python": "bash scripts/ensure-edge-tts.sh scripts/dev-tts.py",
    "local": "NEXT_PUBLIC_LOCAL_MODE=true next dev",
    "analytics:site": "node scripts/site-analytics-report.mjs",
    "build": "bash scripts/build.sh",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@ai-sdk/gateway": "^3.0.66",
    "@clerk/nextjs": "^7.0.4",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^1.3.1",
    "ai": "^6.0.116",
    "convex": "^1.32.0",
    "next": "16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.7",
    "jsdom": "^29.0.0",
    "npm-run-all": "^4.1.5",
    "playwright": "^1.58.2",
    "tailwindcss": "^4",
    "typescript": "^6",
    "vitest": "^4.0.18"
  }
}
