{
  "name": "curio-garden",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "dev": "npm-run-all --parallel dev:frontend dev:backend",
    "dev:python": "npm-run-all --parallel dev:frontend-python dev:backend dev:tts-python",
    "dev:frontend": "next dev",
    "dev:frontend-python": "USE_PYTHON_TTS=true next dev",
    "dev:backend": "convex dev",
    "dev:tts-python": "bash scripts/ensure-edge-tts.sh scripts/dev-tts.py",
    "local": "LOCAL_MODE=true NEXT_PUBLIC_LOCAL_MODE=true next dev",
    "analytics:site": "node scripts/site-analytics-report.mjs",
    "build": "bash scripts/build.sh",
    "start": "next start",
    "lint": "eslint",
    "toolchain:check": "node scripts/validate-toolchain.mjs",
    "typecheck": "npm-run-all typecheck:native typecheck:tooling",
    "typecheck:native": "tsc --noEmit",
    "typecheck:tooling": "tsc6 --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "docs:check": "node scripts/validate-doc-links.mjs",
    "check": "npm-run-all toolchain:check lint typecheck test"
  },
  "dependencies": {
    "@clerk/nextjs": "^7.4.3",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "convex": "^1.40.0",
    "echarts": "^6.1.0",
    "maplibre-gl": "^5.24.0",
    "next": "^16.2.7",
    "openai": "^6.46.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@eslint/compat": "^2.1.0",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "^24.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript/native": "npm:typescript@^7.0.2",
    "eslint": "^10.7.0",
    "eslint-config-next": "^16.2.7",
    "github-slugger": "^2.0.0",
    "jsdom": "^29.1.1",
    "npm-run-all": "^4.1.5",
    "playwright": "^1.61.1",
    "tailwindcss": "^4.3.0",
    "typescript": "npm:@typescript/typescript6@^6.0.2",
    "vitest": "^4.1.8"
  },
  "overrides": {
    "postcss": "^8.5.10"
  }
}
